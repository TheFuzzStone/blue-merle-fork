#!/bin/sh
#
# Thin RPC-style entry point invoked from the LuCI view via fs.exec().
# Each subcommand maps to one of the shell helpers in functions.sh.
#
# NOTE: this executable is exposed to any web user with the
# luci-app-blue-merle ACL, so we keep the surface strictly enumerated
# — no dispatch via $2, no wildcarding.

. /lib/blue-merle/functions.sh

_resolve_tty_for_operation() {
    BLUE_MERLE_TTY=$(_resolve_modem_tty) || return 1
    [ -c "$BLUE_MERLE_TTY" ] || return 1
    export BLUE_MERLE_TTY
}

# Resolve TAC mode from UCI and export the right TAC list path so
# imei_generate.py picks up the correct pool (module vs phone TACs).
# Default is 'module' (86xxxxxx — Quectel/Sierra/Telit/u-blox). Users
# switch to 'phone' (35xxxxxx — smartphone TACs) via LuCI or uci if
# their operator blocks consumer SIMs on module TACs.
_resolve_tac_list() { _resolve_tac_selection; }

_tac_file_has_valid_entry() {
    grep -Eq '^[[:space:]]*[0-9]{8}([[:space:]]*(#.*)?)?$' "$1" 2>/dev/null
}

show_message() {
    # There is mcu_send_message() in /lib/functions/gl_util.sh but we
    # don't want to load the whole file (it is heavy and pulls in a
    # bunch of GL SDK helpers).
    [ -c /dev/ttyS0 ] || return 0
    printf '{"msg":"%s"}\n' "$1" > /dev/ttyS0
}

# Log the event (not the value): the timestamp and command name are the
# useful thing to see in `logread` while debugging, and *do not* include
# any identifiers that could be correlated with an operator's records.
logger -p notice -t blue-merle-libexec "libexec invoked: ${1:-<none>}"

case "$1" in
    read-imei)
        _acquire_modem_lock || { echo "Another modem operation is active" >&2; exit 99; }
        _resolve_tty_for_operation || { echo "No responsive modem TTY found" >&2; exit 1; }
        imei=$(READ_IMEI) || { echo "No IMEI found" >&2; exit 1; }
        # Mask the middle of the IMEI on the MCU screen so a shoulder-
        # surfer / photograph does not immediately capture the full
        # identifier. The full value is still returned on stdout to LuCI.
        #
        # NOTE: ${var:offset:length} is a bashism — busybox ash does not
        # support it. Use cut(1) instead, which is available in busybox.
        masked="$(printf '%s' "$imei" | cut -c1-6)******$(printf '%s' "$imei" | cut -c13-)"
        show_message "IMEI: $masked"
        printf '%s' "$masked"
        ;;

    read-imsi)
        _acquire_modem_lock || { echo "Another modem operation is active" >&2; exit 99; }
        _resolve_tty_for_operation || { echo "No responsive modem TTY found" >&2; exit 1; }
        imsi=$(READ_IMSI) || { echo "No IMSI found" >&2; exit 1; }
        masked="$(printf '%s' "$imsi" | cut -c1-5)******$(printf '%s' "$imsi" | cut -c12-)"
        show_message "IMSI: $masked"
        printf '%s' "$masked"
        ;;

    read-tac-mode)
        # Return the current TAC mode for the LuCI dropdown.
        uci -q get blue-merle.main.tac_mode 2>/dev/null || echo module
        ;;

    set-tac-mode-module|set-tac-mode-phone)
        mode_val=${1##set-tac-mode-}
        if [ "$mode_val" = "phone" ] && ! _tac_file_has_valid_entry /lib/blue-merle/tac-list-phone.txt; then
            echo "phone TAC mode requires at least one verified 8-digit TAC in tac-list-phone.txt" >&2
            exit 1
        fi
        uci set blue-merle.main.tac_mode="$mode_val" || exit 1
        uci commit blue-merle || exit 1
        logger -p notice -t blue-merle-libexec "TAC mode set to $mode_val"
        echo "TAC mode: $mode_val"
        ;;

    prepare-sim-swap)
        _sim_swap_pending && { echo "Hardware-toggle SIM swap is awaiting stage 2" >&2; exit 1; }
        _acquire_modem_lock || { echo "Another modem operation is active" >&2; exit 99; }
        _resolve_tty_for_operation || { echo "No responsive modem TTY found" >&2; exit 1; }
        _resolve_tac_list
        tries=0
        until gl_modem AT AT+CFUN=4 | grep -q OK; do
            tries=$((tries+1))
            [ "$tries" -ge 15 ] && { echo "CFUN=4 failed" >&2; exit 1; }
            sleep 1
        done
        sleep 2
        timeout 15 python3 /lib/blue-merle/imei_generate.py --random >/dev/null \
            || { echo "Interim IMEI change failed" >&2; exit 1; }
        READ_IMEI | sed -E 's/^(.{4}).*(.{4})$/\1******\2/'
        ;;

    shutdown)
        show_message "Shutting down..."
        printf 'Shutting down'
        if [ -c /dev/ttyS0 ]; then
            printf '{"poweroff":"1"}\n' > /dev/ttyS0
        else
            /sbin/poweroff
        fi
        ;;

    *)
        echo "unknown subcommand: ${1:-<none>}" >&2
        exit 2
        ;;
esac
