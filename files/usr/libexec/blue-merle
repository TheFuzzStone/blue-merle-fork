#!/bin/sh
#
# Thin RPC-style entry point invoked from the LuCI view via fs.exec().
# Each subcommand maps to one of the shell helpers in functions.sh.
#
# NOTE: this executable is exposed to any web user with the
# luci-app-blue-merle ACL, so we keep the surface strictly enumerated
# — no dispatch via $2, no wildcarding.

. /lib/blue-merle/functions.sh

_resolve_tty_for_operation() {
    BLUE_MERLE_TTY=$(_resolve_modem_tty) || return 1
    [ -c "$BLUE_MERLE_TTY" ] || return 1
    export BLUE_MERLE_TTY
}

# Resolve TAC mode from UCI and export the matching selection so
# imei_generate.py picks up the right source. Default is 'module'
# (preserve the baseline modem TAC; no external database). Users can
# switch to 'phone' (their own verified TAC list) via LuCI or uci.
# Policy: never infer device class from TAC prefixes.
_resolve_tac_list() { _resolve_tac_selection; }

_tac_file_has_valid_entry() {
    grep -Eq '^[[:space:]]*[0-9]{8}([[:space:]]*(#.*)?)?$' "$1" 2>/dev/null
}

show_message() {
    # There is mcu_send_message() in /lib/functions/gl_util.sh but we
    # don't want to load the whole file (it is heavy and pulls in a
    # bunch of GL SDK helpers).
    [ -c /dev/ttyS0 ] || return 0
    printf '{"msg":"%s"}\n' "$1" > /dev/ttyS0
}

# Log the event (not the value): the timestamp and command name are the
# useful thing to see in `logread` while debugging, and *do not* include
# any identifiers that could be correlated with an operator's records.
logger -p notice -t blue-merle-libexec "libexec invoked: ${1:-<none>}"

case "$1" in
    read-identifiers)
        _acquire_modem_lock || { echo "Another modem operation is active" >&2; exit 99; }
        _resolve_tty_for_operation || { echo "No responsive modem TTY found" >&2; exit 1; }
        imei=$(READ_IMEI) || { echo "No IMEI found" >&2; exit 1; }
        imsi=$(READ_IMSI || true)
        masked_imei="$(printf '%s' "$imei" | cut -c1-6)******$(printf '%s' "$imei" | cut -c13-)"
        if [ -n "$imsi" ]; then
            masked_imsi="$(printf '%s' "$imsi" | cut -c1-5)******$(printf '%s' "$imsi" | cut -c12-)"
        else
            masked_imsi=""
        fi
        printf '{"imei":"%s","imsi":"%s"}\n' "$masked_imei" "$masked_imsi"
        ;;

    read-tac-mode)
        # Return the current TAC mode for the LuCI dropdown.
        uci -q get blue-merle.main.tac_mode 2>/dev/null || echo module
        ;;

    set-tac-mode-module|set-tac-mode-phone)
        mode_val=${1##set-tac-mode-}
        if [ "$mode_val" = "phone" ] && ! _tac_file_has_valid_entry /lib/blue-merle/tac-list-phone.txt; then
            echo "phone TAC mode requires at least one verified 8-digit TAC in tac-list-phone.txt" >&2
            exit 1
        fi
        uci set blue-merle.main.tac_mode="$mode_val" || exit 1
        uci commit blue-merle || exit 1
        logger -p notice -t blue-merle-libexec "TAC mode set to $mode_val"
        echo "TAC mode: $mode_val"
        ;;

    prepare-sim-swap)
        _sim_swap_pending && { echo "Hardware-toggle SIM swap is awaiting stage 2" >&2; exit 1; }
        _acquire_modem_lock || { echo "Another modem operation is active" >&2; exit 99; }
        _resolve_tty_for_operation || { echo "No responsive modem TTY found" >&2; exit 1; }
        _resolve_tac_list
        # Capture the current IMEI for the post-write comparison. An empty
        # value is tolerated (stage2 allows it too): the readback checks
        # below are the real gate.
        old_imei=$(READ_IMEI || true)
        tries=0
        until gl_modem AT AT+CFUN=4 | grep -q OK; do
            tries=$((tries+1))
            [ "$tries" -ge 15 ] && { echo "CFUN=4 failed; modem state unchanged, retry or reboot" >&2; exit 1; }
            sleep 1
        done
        sleep 2
        if ! timeout 15 python3 /lib/blue-merle/imei_generate.py --random >/dev/null; then
            echo "IMEI write failed; do NOT swap the SIM, retry or reboot to restore service" >&2
            exit 1
        fi
        # This flow has no stage 2: the value written above becomes the
        # on-air IMEI after reboot, so the same fail-closed invariants as
        # blue-merle-switch-stage2 apply before success may be reported.
        # Anything else risks the user swapping the SIM into a
        # half-applied modem state (old IMEI associated with new IMSI).
        new_imei=$(READ_IMEI || true)
        if ! _is_valid_imei_shape "$new_imei"; then
            echo "IMEI readback invalid; powering off" >&2
            _safe_poweroff
            exit 1
        elif [ -n "$old_imei" ] && [ "$old_imei" = "$new_imei" ]; then
            echo "IMEI unchanged after write; powering off" >&2
            _safe_poweroff
            exit 1
        fi
        if ! _write_runtime_imei "$new_imei"; then
            echo "Volatile IMEI storage unavailable; powering off" >&2
            _safe_poweroff
            exit 1
        fi
        # Same masked form as read-identifiers (first 6 + last 3
        # digits), and only after every check above passed — never mask
        # a failed read behind a pipeline (exit status would be sed's).
        masked="$(printf '%s' "$new_imei" | cut -c1-6)******$(printf '%s' "$new_imei" | cut -c13-)"
        printf '%s' "$masked"
        ;;

    shutdown)
        show_message "Shutting down..."
        printf 'Shutting down'
        if [ -c /dev/ttyS0 ]; then
            printf '{"poweroff":"1"}\n' > /dev/ttyS0
        else
            /sbin/poweroff
        fi
        ;;

    *)
        echo "unknown subcommand: ${1:-<none>}" >&2
        exit 2
        ;;
esac
