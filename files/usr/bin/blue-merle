#!/bin/sh
#
# Interactive CLI for changing the Mudi's IMEI. See also the toggle-driven
# workflow in /usr/bin/blue-merle-switch-stage{1,2} and the LuCI view.

. /lib/blue-merle/functions.sh

_sim_swap_pending && {
	echo "A hardware-toggle SIM swap is awaiting stage 2. Complete it before using the CLI." >&2
	exit 1
}

_acquire_modem_lock || {
	echo "Another modem operation is in progress. Try again shortly." >&2
	exit 99
}

# Resolve the modem's AT-command TTY (see _resolve_modem_tty in
# functions.sh). Falls back gracefully if the port has shifted after a
# firmware update or USB re-enumeration; can be overridden by exporting
# BLUE_MERLE_TTY before invocation.
BLUE_MERLE_TTY=$(_resolve_modem_tty)
if [ ! -c "$BLUE_MERLE_TTY" ]; then
	echo "Error: no modem TTY found (expected $BLUE_MERLE_TTY)."
	echo "Please reboot and contact the maintainer if the problem persists."
	exit 1
fi
export BLUE_MERLE_TTY

_resolve_tac_selection

printf 'Swap SIM card and update IMEI? (Y/n): '
read -r answer
case $answer in
	n*|N*) answer=0;;
	*) answer=1;;
esac
if [ "$answer" -eq 0 ]; then
	exit 1
fi


echo "Disabling the ME from both transmitting and receiving RF signals..."

old_imei=$(READ_IMEI)
old_imsi=$(READ_IMSI)

answer=1
while [ "$answer" -eq 1 ]; do
	if gl_modem AT AT+CFUN=4 | grep -q OK; then
		answer=0
	else
		printf '...failed. Try again? (Y/n): '
		read -r reply
		case $reply in
			n*|N*) exit 1 ;;
		esac
	fi
done

# CFUN=4 is asynchronous; give the modem a moment to fully release RF before
# writing EGMR. Otherwise the new IMEI may collide with a pending network
# attach using the old IMEI.
sleep 2

## We have just disabled the modem so it should not log on to any network.
## We set a random IMEI now only to have it overwritten very soon after
## the SIM card has been replaced. We intend to prevent an accidential
## leak of the new SIM's IMSI with the old IMEI just in case the modem
## accidentally tried to log in to the network.
if ! python3 /lib/blue-merle/imei_generate.py -r; then
	echo "ERROR: interim IMEI set failed; powering off before SIM swap." >&2
	_safe_poweroff
	exit 1
fi


printf 'Please now replace the SIM card and press any key to continue. '
read -r answer

leak=0
max_cfun_retries=30

cfun0_tries=0
until gl_modem AT AT+CFUN=0 | grep -q OK
do
	cfun0_tries=$((cfun0_tries+1))
	if [ "$cfun0_tries" -ge "$max_cfun_retries" ]; then
		echo "CFUN=0 failed after $max_cfun_retries attempts; aborting."
		exit 1
	fi
	sleep 1
	echo "CFUN=0 failed. Trying again. ($cfun0_tries/$max_cfun_retries)"
done

cfun4_tries=0
until gl_modem AT AT+CFUN=4 | grep -q OK
do
	leak=1
	cfun4_tries=$((cfun4_tries+1))
	if [ "$cfun4_tries" -ge "$max_cfun_retries" ]; then
		echo "CFUN=4 failed after $max_cfun_retries attempts; aborting."
		exit 1
	fi
	sleep 1
	echo "CFUN=4 failed. Trying again. ($cfun4_tries/$max_cfun_retries)"
done

if [ "$leak" -eq 1 ]; then
	echo
	echo "WARNING: Reset took longer than expected."
	echo
fi

sleep 2

new_imsi=$(READ_IMSI)

if [ -z "$new_imsi" ]; then
	echo
	echo "WARNING: No SIM detected after swap. Insert a SIM before proceeding."
	echo
elif [ "$old_imsi" = "$new_imsi" ]; then
	echo
	echo "WARNING: Old IMSI equals new IMSI. Did you actually swap the SIM?"
	echo
fi

printf 'Would you like to set a random (r) or deterministic (d) IMEI? (R/d): '
read -r answer
case $answer in
	d*|D*) answer=0;;
	*) answer=1;;
esac
if [ "$answer" -eq 1 ]; then
	python3 /lib/blue-merle/imei_generate.py -r >/dev/null || {
		echo "ERROR: final IMEI change failed; powering off." >&2
		_safe_poweroff
		exit 1
	}
else
	python3 /lib/blue-merle/imei_generate.py -d >/dev/null || {
		echo "ERROR: deterministic IMEI change failed; powering off." >&2
		_safe_poweroff
		exit 1
	}
fi

new_imei=$(READ_IMEI)

if ! _is_valid_imei_shape "$new_imei"; then
	echo "ERROR: IMEI readback is not a valid 15-digit value; powering off." >&2
	_safe_poweroff
	exit 1
elif [ "$old_imei" = "$new_imei" ]; then
	echo
	echo "WARNING: Old IMEI equals new IMEI."
	echo
	_safe_poweroff
	exit 1
else
	_write_runtime_imei "$new_imei" || {
		echo "ERROR: volatile IMEI storage is not mounted; powering off." >&2
		_safe_poweroff
		exit 1
	}
fi

echo "You should now reset the modem or shutdown the device."
echo "For extra privacy, you should shutdown the device and change your location."
echo
printf 'Would you like to shutdown the device (s) or reset the modem (m)? (S/m): '
read -r answer
case $answer in
	m*|M*) answer=0;;
	*) answer=1;;
esac
# Wipe sensitive variables before we hand control back to the user or shut
# down: nothing further needs them and they should not linger in shell
# process memory.
unset old_imei new_imei old_imsi new_imsi
if [ "$answer" -eq 1 ]; then
    if [ -c /dev/ttyS0 ]; then
        echo '{ "msg": "Shutting down..." }' > /dev/ttyS0
        echo '{ "poweroff": "1" }' > /dev/ttyS0
    else
        /sbin/poweroff
    fi
else
	echo "Resetting modem..."
	# AT+CFUN=1,1 performs a full reset (equivalent to power cycle) and keeps
	# the modem reachable afterwards. AT+QPOWD would power the modem OFF and
	# then AT+CIMI could never succeed, leading to an infinite wait loop.
	reset_attempts=0
	until gl_modem AT "AT+CFUN=1,1" | grep -q OK
	do
		reset_attempts=$((reset_attempts+1))
		if [ "$reset_attempts" -ge 10 ]; then
			echo "Resetting modem failed 10 times; aborting."
			exit 1
		fi
		echo "Resetting modem failed. Trying again."
		sleep 1
	done

	time_start=$(date +%s)
	timeout_sec=60
	# grep -q prints nothing: the IMSI never touches the terminal or a
	# shell variable here. The pipeline's exit status is the gate.
	until gl_modem AT AT+CIMI | grep -q -w -E "[0-9]{6,15}"
	do
		time_now=$(date +%s)
		elapsed=$((time_now-time_start))
		if [ "$elapsed" -ge "$timeout_sec" ]; then
			echo
			echo "Modem did not come back within ${timeout_sec}s; aborting."
			exit 1
		fi
		printf 'Waiting for reset to complete. (%ss/%ss)\r' "$elapsed" "$timeout_sec"
		sleep 1
	done
	echo
	echo "FIN"
fi
	
