#!/bin/sh
#
# Rotate the AP SSID to a fresh "<Name>'s iPhone" without a reboot.
#
# The hostname is rotated along with it (to the matching
# "<Name>s-iPhone") so the SSID and the DHCP hostname always tell the
# same story — hostname changes are invisible to AP clients.
#
# The Wi-Fi password is *not* touched: clients only need to click
# "Connect" on the new network and re-enter the same password they
# used before.
#
# Usage:
#   blue-merle-newssid              # rotate SSID and reload wifi
#   blue-merle-newssid --dry-run    # preview the next SSID without applying
#   blue-merle-newssid --preview    # show the current SSID and exit
#
# Exits 0 on success, non-zero on failure.

set -eu

. /lib/blue-merle/functions.sh

MODE=apply

for arg in "$@"; do
    case "$arg" in
        --dry-run) MODE=dry ;;
        --preview) MODE=preview ;;
        -h|--help)
            sed -n 's/^# \{0,1\}//p' "$0" | sed -n '3,16p'
            exit 0
            ;;
        *)
            echo "unknown option: $arg" >&2
            exit 2
            ;;
    esac
done

current=$(uci -q get wireless.@wifi-iface[0].ssid || echo "<unset>")

case "$MODE" in
    preview)
        echo "Current SSID: $current"
        exit 0
        ;;
    dry)
        # Compose a candidate exactly the way RANDOMIZE_IDENTITY does,
        # but do not write anything.
        name=$(_pick_iphone_name) || {
            echo "Cannot read the first-name pool" >&2
            exit 1
        }
        echo "Current SSID:       $current"
        echo "Would set SSID:     ${name}'s iPhone"
        echo "Would set hostname: $(_iphone_hostname_from_name "$name")"
        exit 0
        ;;
esac

echo "Rotating SSID+hostname (current: $current)..."
RANDOMIZE_IDENTITY || { echo "Identity rotation failed" >&2; exit 1; }
new=$(uci -q get wireless.@wifi-iface[0].ssid || echo "<unset>")
if [ "$new" = "<unset>" ]; then
    echo "Identity rotation failed" >&2
    exit 1
fi
echo "Reloading wifi..."
wifi reload || { echo "wifi reload failed" >&2; exit 1; }

echo
echo "Done. New SSID: $new"
echo "Hostname synced: $(uci -q get system.@system[0].hostname || echo '<unknown>')"
echo "Clients must click 'Connect' on the new network — the password is"
echo "unchanged, so they can reuse the one they were already using."
