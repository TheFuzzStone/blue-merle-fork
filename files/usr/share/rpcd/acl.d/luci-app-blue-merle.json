{
	"luci-app-blue-merle": {
		"description": "Grant access to blue-merle (IMEI/IMSI reading, SIM-swap workflow, TAC mode)",
		"read": {
			"cgi-io": [ "exec" ],
			"file": {
				"/usr/libexec/blue-merle read-imei": [ "exec" ],
				"/usr/libexec/blue-merle read-imsi": [ "exec" ],
				"/usr/libexec/blue-merle read-tac-mode": [ "exec" ]
			}
		},
		"write": {
			"file": {
				"/usr/libexec/blue-merle prepare-sim-swap": [ "exec" ],
				"/usr/libexec/blue-merle shutdown": [ "exec" ],
				"/usr/libexec/blue-merle set-tac-mode": [ "exec" ]
			}
		}
	}
}
